# .gitignore

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg

# ── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Data & Models (never commit large files) ─────────────────────────────────
*.parquet
*.arrow
*.pkl
*.bin
*.onnx
data/
models/
embeddings/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/
