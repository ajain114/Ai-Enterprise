# .env.example
# =============
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env

# ── Database — pgvector ───────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_rag_platform
PG_USER=rag_reader
PG_PASSWORD=changeme
PG_SCHEMA=rag

# ── Embedding & Vector Store ──────────────────────────────────────────────────
EMBEDDING_TABLE=document_chunks
EMBEDDING_DIM=1536

# ── AWS — Bedrock (LLM + Embeddings + Reranking) ─────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: use IAM role in production instead of access keys
# AWS_PROFILE=your-aws-profile

EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
RERANK_MODEL_ID=amazon.rerank-v1:0
LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── AWS — Storage & Governance ────────────────────────────────────────────────
AUDIT_S3_BUCKET=your-ai-audit-logs-bucket
FEATURE_STORE_S3_BUCKET=your-feature-store-bucket
TOKEN_VAULT_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret/pii-token-vault

# ── Online Feature Store (Redis) ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Lineage (Marquez / OpenLineage) ──────────────────────────────────────────
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=mcp-ai-platform

# ── PII Configuration ─────────────────────────────────────────────────────────
PII_CONFIG_PATH=config/pii_config.yaml
ACCESS_POLICY_PATH=config/access_policy.yaml

# ── Server ────────────────────────────────────────────────────────────────────
DEFAULT_TOP_K=10
RERANK_TOP_K=3
MAX_TOP_K=20
LOG_LEVEL=INFO

# ── Local Dev (MinIO as S3 replacement) ──────────────────────────────────────
# Uncomment for local development with docker-compose:
# AWS_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=admin
# AWS_SECRET_ACCESS_KEY=changeme123
